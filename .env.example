# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Vercel Postgres, Neon, Supabase, etc.)
# Leave empty to use SQLite (local dev only)
DATABASE_URL=postgresql://user:password@host:5432/asterope

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_hex(32))"
ASTEROPE_SECRET=change-me-in-production

# Initial admin password (only used when creating the admin account for the first time)
ASTEROPE_ADMIN_PASS=asterope2026

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or * for all (dev only)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Flask ─────────────────────────────────────────────────────────────────────
# Set to 1 to enable Flask debug mode (never in production)
FLASK_DEBUG=0
